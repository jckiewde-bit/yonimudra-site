# ─── EssorCare Supabase (the same project the therapist app uses) ────────────
# These are used only to POST to the public-intake Edge Function and to
# read the /join/:token telehealth bridge. Use the ANON key — never the
# service role — in a public-facing marketing site.
NEXT_PUBLIC_SUPABASE_URL=https://yvcduisiodkbtavjgfzl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Public intake wiring ────────────────────────────────────────────────────
# The therapist-profile UUID that new leads are attached to. For a solo
# practice this is Jacqueline's profiles.id (fd53aba7-afcd-49d2-a921-a41603b00fcf).
# Leaving this blank falls back to the Edge Function's default.
NEXT_PUBLIC_THERAPIST_ID=fd53aba7-afcd-49d2-a921-a41603b00fcf

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Yoni Mudra Creative Arts Counseling & Coaching"

# ─── Telehealth bridge ───────────────────────────────────────────────────────
# yonimudrahealing.com/join/<token> redirects here. Points at the deployed EssorCare
# therapist app; during local EssorCare dev, set to http://localhost:5173.
NEXT_PUBLIC_ESSORCARE_APP_URL=https://app.essorcare.com
